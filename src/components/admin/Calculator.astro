  .btn-primary { background: #c9a96e; color: #0f1f2e; border-color: #c9a96e; }
  .btn-primary:hover { background: #dfc090; border-color: #dfc090; }
  .btn-primary:disabled { opacity: .4; cursor: not-allowed; }
  .btn-ghost { background: none; color: rgba(15,31,46,.7); border-color: rgba(15,31,46,.25); }
  .btn-ghost:hover { border-color: #0f1f2e; color: #0f1f2e; }
  .btn-ghost:disabled { opacity: .4; cursor: not-allowed; }
  .btn-sm { padding: 7px 14px; font-size: .7rem; }
  .btn svg { width: 13px; height: 13px; stroke: currentColor; fill: none; stroke-width: 1.8; stroke-linecap: round; stroke-linejoin: round; }

  .view-saved-link { padding-top: 4px; text-align: center; }
  .view-saved-link a { font-size: .72rem; color: #a8885a; letter-spacing: .04em; text-decoration: none; transition: color .2s; }
  .view-saved-link a:hover { color: #c9a96e; }

  /* Modal */
  .modal-backdrop { position: fixed; inset: 0; background: rgba(15,31,46,.35); z-index: 200; }
