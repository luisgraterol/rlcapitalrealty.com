        <!-- Actions -->
        <div class="calc-actions">
          <button class="btn btn-primary" id="btn-save" type="button" disabled>
            <svg viewBox="0 0 24 24"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
            Save Analysis
          </button>
          <button class="btn btn-ghost" id="btn-update" type="button" style="display:none">
            <svg viewBox="0 0 24 24"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
            Update
          </button>
          <button class="btn btn-ghost" id="btn-new" type="button" style="display:none">New Analysis</button>
          <button class="btn btn-ghost" id="btn-export" type="button">
            <svg viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Export .md
