---
---

<div class="page">
  <div class="portal-content">

    <div class="section-label">Property Financial Analyzer</div>

    <div class="calc-layout">

      <!-- INPUT PANEL -->
      <div class="calc-panel">
        <div class="calc-panel-title">
          Inputs
          <span id="current-analysis-id" style="display:none"></span>
        </div>

        <!-- Property Association -->
        <div class="property-assoc">
          <div class="property-assoc-row">
            <div class="field-group" style="flex:1;min-width:0">
              <label for="inp-property">Linked Property</label>
              <select id="inp-property">
                <option value="">— Select a property —</option>
              </select>
            </div>
            <button id="btn-new-property" type="button" class="btn-add-prop" title="Add new property">
              <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              New
            </button>
          </div>
          <div id="orphan-warning" class="assoc-banner warn" style="display:none">
            This analysis has no linked property. Select one above before saving.
          </div>
          <div id="no-property-hint" class="assoc-banner info" style="display:none">
            Select a property above to enable saving.
          </div>
          <div id="no-properties-hint" class="assoc-banner info" style="display:none">
            No properties yet. <a href="/admin/properties">Create one first →</a>
          </div>
        </div>

        <!-- Section 1: Property Basics -->
        <div class="calc-section">
          <button class="calc-section-toggle open" data-target="sec-basics" type="button">
            Property Basics
            <svg viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <div class="calc-section-body open" id="sec-basics">
            <div class="field-row full">
              <div class="field-group">
                <label for="inp-name">Analysis Label</label>
                <input type="text" id="inp-name" value="New Analysis" placeholder="e.g. 1234 Oak St — Summer" />
              </div>
            </div>
            <div class="field-row full">
              <div class="field-group">
                <label for="inp-address">Property Address</label>
                <input type="text" id="inp-address" placeholder="Auto-filled from linked property" readonly />
              </div>
            </div>
            <div class="field-row">
              <div class="field-group">
                <label for="inp-bedrooms">Bedrooms</label>
                <input type="text" id="inp-bedrooms" disabled class="prop-auto-field" placeholder="— from property —" />
              </div>
              <div class="field-group">
                <label for="inp-bathrooms">Bathrooms</label>
                <input type="text" id="inp-bathrooms" disabled class="prop-auto-field" placeholder="— from property —" />
              </div>
            </div>
            <div class="field-row">
              <div class="field-group">
                <label for="inp-type">Property Type</label>
                <input type="text" id="inp-type" disabled class="prop-auto-field" placeholder="— from property —" />
              </div>
              <div class="field-group"></div>
            </div>
            <div class="field-row">
              <div class="field-group">
                <label for="inp-rent-ask">Monthly Rent (Ask)</label>
                <input type="number" id="inp-rent-ask" value="1400" min="0" step="50" />
              </div>
              <div class="field-group">
                <label for="inp-rent-neg">Monthly Rent (Negotiated)</label>
                <input type="number" id="inp-rent-neg" value="1200" min="0" step="50" />
              </div>
            </div>
            <div class="field-row">
              <div class="field-group">
                <label for="inp-deposit">Security Deposit</label>
                <input type="number" id="inp-deposit" value="1400" min="0" step="50" />
              </div>
              <div class="field-group">
                <label for="inp-hoa">HOA Present?</label>
                <select id="inp-hoa">
                  <option value="No" selected>No</option>
                  <option value="Yes">Yes</option>
                </select>
              </div>
            </div>
            <div class="field-row">
              <div class="field-group">
                <label for="inp-walk-away">Walk-Away Threshold ($)</label>
                <input type="number" id="inp-walk-away" value="1750" min="0" step="50" />
                <span class="field-note">Max monthly rent R&amp;L will sign</span>
              </div>
              <div class="field-group"></div>
            </div>
            <div class="hoa-block" id="hoa-block">
              <div class="hoa-block-title">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                HOA Detected — Property Disqualified
              </div>
              <p class="hoa-block-body">R&amp;L Capital Realty does not lease HOA properties under any circumstances.</p>
            </div>
          </div>
        </div>

        <!-- Section 2: Revenue Assumptions -->
        <div class="calc-section">
          <button class="calc-section-toggle open" data-target="sec-revenue" type="button">
            Revenue Assumptions
            <svg viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <div class="calc-section-body open" id="sec-revenue">
            <div class="field-row">
              <div class="field-group">
                <label for="inp-adr">ADR — Avg Daily Rate ($)</label>
                <input type="number" id="inp-adr" value="167" min="0" step="1" />
                <span class="field-note">AirDNA Abilene 2BR avg</span>
              </div>
              <div class="field-group">
                <label for="inp-occ">Occupancy Rate (%)</label>
                <input type="number" id="inp-occ" value="77" min="0" max="100" step="1" />
                <span class="field-note">AirDNA Abilene annual avg</span>
              </div>
            </div>
            <div class="field-row">
              <div class="field-group">
                <label for="inp-stay">Avg Stay Length (nights)</label>
                <input type="number" id="inp-stay" value="3.2" min="1" step="0.1" />
                <span class="field-note">Abilene military/university profile</span>
              </div>
              <div class="field-group">
                <label for="inp-demand">Primary Demand Driver</label>
                <select id="inp-demand">
                  <option value="Military TDY" selected>Military TDY</option>
                  <option value="University Events">University Events</option>
                  <option value="Mixed">Mixed</option>
                  <option value="Corporate/Contractor">Corporate / Contractor</option>
                </select>
              </div>
            </div>
          </div>
        </div>

        <!-- Section 3: Fixed Monthly Costs -->
        <div class="calc-section">
          <button class="calc-section-toggle open" data-target="sec-fixed" type="button">
            Fixed Monthly Costs
            <svg viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <div class="calc-section-body open" id="sec-fixed">

            <div class="calc-subsection-title">Utilities</div>
            <div class="field-row">
              <div class="field-group">
                <label for="inp-electricity">Electricity (AEP Texas)</label>
                <input type="number" id="inp-electricity" value="130" min="0" step="1" />
                <span class="field-note">$120–$140 (2BR) · $145–$170 (3BR)</span>
              </div>
              <div class="field-group">
                <label for="inp-water">Water</label>
                <input type="number" id="inp-water" value="45" min="0" step="1" />
                <span class="field-note">$40–$50 (2BR) · $50–$60 (3BR) · confirm if landlord-included</span>
              </div>
            </div>
            <div class="field-row">
              <div class="field-group">
                <label for="inp-sewer">Sewer</label>
                <input type="number" id="inp-sewer" value="50" min="0" step="1" />
                <span class="field-note">$45–$55 (2BR) · $55–$65 (3BR) · confirm if landlord-included</span>
              </div>
              <div class="field-group">
                <label for="inp-garbage">Garbage (City of Abilene)</label>
                <input type="number" id="inp-garbage" value="24" min="0" step="1" />
                <span class="field-note">$24 flat · confirm if landlord-included</span>
              </div>
            </div>

            <div class="calc-subsection-title">Internet &amp; Insurance</div>
            <div class="field-row">
              <div class="field-group">
                <label for="inp-internet">Internet (fiber)</label>
                <input type="number" id="inp-internet" value="80" min="0" step="1" />
              </div>
              <div class="field-group">
                <label for="inp-insurance">STR Insurance (Proper)</label>
                <input type="number" id="inp-insurance" value="100" min="0" step="1" />
                <span class="field-note">Quote in hand: $98–103/mo</span>
              </div>
            </div>

            <div class="calc-subsection-title">Supplies</div>
            <div class="field-row">
              <div class="field-group">
                <label for="inp-supplies">Supplies &amp; Amenities</label>
                <input type="number" id="inp-supplies" value="120" min="0" step="5" />
              </div>
              <div class="field-group">
                <label for="inp-linens">Linens &amp; Towels (reserve)</label>
                <input type="number" id="inp-linens" value="41" min="0" step="1" />
                <span class="field-note">$35 (2BR) · $48 (3BR)</span>
              </div>
            </div>

            <div class="calc-subsection-title">Tech &amp; Platforms</div>
            <div class="field-row">
              <div class="field-group">
                <label for="inp-pms">PMS Software (Hospitable)</label>
                <input type="number" id="inp-pms" value="39" min="0" step="1" />
              </div>
              <div class="field-group">
                <label for="inp-pricing">Dynamic Pricing (PriceLabs)</label>
                <input type="number" id="inp-pricing" value="0" min="0" step="1" />
              </div>
            </div>
            <div class="field-row">
              <div class="field-group">
                <label for="inp-minut-subscription">Minut (noise sensor)</label>
                <input type="number" id="inp-minut-subscription" value="10" min="0" step="1" />
                <span class="field-note">$10 flat</span>
              </div>
              <div class="field-group">
                <label for="inp-streaming">Streaming (Netflix/Hulu)</label>
                <input type="number" id="inp-streaming" value="8" min="0" step="1" />
                <span class="field-note">$8 flat · guest profile</span>
              </div>
            </div>

            <div class="calc-subsection-title">Maintenance &amp; Admin</div>
            <div class="field-row">
              <div class="field-group">
                <label>Maintenance Reserve</label>
                <input type="number" id="inp-maintenance" readonly />
                <span class="field-note">Auto: 1.5% of negotiated rent (min $75, max $150)</span>
              </div>
              <div class="field-group">
                <label for="inp-preventive-inspection">Preventive Inspection</label>
                <input type="number" id="inp-preventive-inspection" value="50" min="0" step="1" />
                <span class="field-note">$50 · handyman · every 2 mo (6x/yr) · prorated</span>
              </div>
            </div>
            <div class="field-row">
              <div class="field-group">
                <label for="inp-hvac-filters">HVAC Filters</label>
                <input type="number" id="inp-hvac-filters" value="10" min="0" step="1" />
                <span class="field-note">$8 (2BR) · $12 (3BR) · every 45–60 days · prorated</span>
              </div>
              <div class="field-group">
                <label for="inp-cpa">CPA / Taxes</label>
                <input type="number" id="inp-cpa" value="42" min="0" step="1" />
                <span class="field-note">~$500/yr billed Q1 · prorated</span>
              </div>
            </div>
            <div class="field-row">
              <div class="field-group">
                <label>STR Permit</label>
                <input type="number" value="0" readonly disabled />
                <span class="field-note"><span class="field-badge">No permit required — City of Abilene (2026)</span></span>
              </div>
              <div class="field-group"></div>
            </div>
          </div>
        </div>

        <!-- Section 3b: Property Services -->
        <div class="calc-section">
          <button class="calc-section-toggle" data-target="sec-property-services" type="button">
            Property Services
            <svg viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <div class="calc-section-body" id="sec-property-services">
            <div class="field-row">
              <div class="field-group">
                <label for="inp-has-yard">Has Yard?</label>
                <select id="inp-has-yard">
                  <option value="No" selected>No</option>
                  <option value="Yes">Yes</option>
                </select>
                <span class="field-note">Enables lawn care cost when Yes</span>
              </div>
              <div class="field-group">
                <label for="inp-lawn-care">Lawn Care</label>
                <input type="number" id="inp-lawn-care" value="0" min="0" step="1" readonly />
                <span class="field-note">$75 (2BR) · $82 (3BR) · Apr–Oct 2x/mo, Nov–Mar 1x/mo · prorated</span>
              </div>
            </div>
            <div class="field-row">
              <div class="field-group">
                <label for="inp-pest-control">Pest Control</label>
                <input type="number" id="inp-pest-control" value="51" min="0" step="1" />
                <span class="field-note">$50 (2BR) · $53 (3BR) · quarterly · prorated</span>
              </div>
              <div class="field-group">
                <label for="inp-bulk-pickup">Bulk Pickup</label>
                <input type="number" id="inp-bulk-pickup" value="8" min="0" step="1" />
                <span class="field-note">~2x/yr · prorated</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Section 4: Per-Stay Variable Costs -->
        <div class="calc-section">
          <button class="calc-section-toggle" data-target="sec-variable" type="button">
            Per-Stay Variable Costs
            <svg viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <div class="calc-section-body" id="sec-variable">
            <div class="field-row">
              <div class="field-group">
                <label for="inp-cleaning">Cleaning Fee per Stay ($)</label>
                <input type="number" id="inp-cleaning" value="120" min="0" step="5" />
                <span class="field-note">Pass-through: charged to guest = paid to cleaner. Net P&amp;L impact = $0.</span>
              </div>
              <div class="field-group">
                <label for="inp-airbnb-fee-type">Airbnb Host Fee</label>
                <select id="inp-airbnb-fee-type">
                  <option value="3%">3% — Direct (no API)</option>
                  <option value="15.5%">15.5% — Hospitable API</option>
                </select>
                <span class="field-note">Verify in Airbnb → Payments &amp; Payouts. API-connected = 15.5%.</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Section 5: Setup & One-Time Costs -->
        <div class="calc-section">
          <button class="calc-section-toggle" data-target="sec-setup" type="button">
            Setup &amp; One-Time Costs
            <svg viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <div class="calc-section-body" id="sec-setup">
            <div class="field-row">
              <div class="field-group">
                <label for="inp-furniture">Furniture &amp; Décor</label>
                <input type="number" id="inp-furniture" value="6500" min="0" step="100" />
                <span class="field-note">2BR standard</span>
              </div>
              <div class="field-group">
                <label for="inp-photo">Photography</label>
                <input type="number" id="inp-photo" value="205" min="0" step="50" />
                <span class="field-note">$180–$230 (2BR)</span>
              </div>
            </div>
            <div class="field-row">
              <div class="field-group">
                <label for="inp-lock">Smart Lock</label>
                <input type="number" id="inp-lock" value="180" min="0" step="10" />
                <span class="field-note">Schlage/Yale</span>
              </div>
              <div class="field-group">
                <label for="inp-minut-hardware">Minut Hardware</label>
                <input type="number" id="inp-minut-hardware" value="100" min="0" step="10" />
                <span class="field-note">$100 flat</span>
              </div>
            </div>
            <div class="field-row">
              <div class="field-group">
                <label for="inp-wifi-router">WiFi Router (premium)</label>
                <input type="number" id="inp-wifi-router" value="100" min="0" step="10" />
                <span class="field-note">$80 (2BR) · $120 (3BR)</span>
              </div>
              <div class="field-group">
                <label for="inp-welcome-kits">Welcome Kits (2-mo supply)</label>
                <input type="number" id="inp-welcome-kits" value="195" min="0" step="5" />
                <span class="field-note">$170 (2BR) · $220 (3BR)</span>
              </div>
            </div>
            <div class="field-row">
              <div class="field-group">
                <label>LLC Formation</label>
                <input type="number" value="0" readonly disabled />
                <span class="field-note">Already registered — locked at $0</span>
              </div>
              <div class="field-group">
                <label for="inp-legal">Legal (Sublease Addendum)</label>
                <input type="number" id="inp-legal" value="400" min="0" step="50" />
                <span class="field-note">TX attorney quote</span>
              </div>
            </div>
            <div class="field-row">
              <div class="field-group">
                <label for="inp-misc">Miscellaneous Buffer</label>
                <input type="number" id="inp-misc" value="500" min="0" step="50" />
              </div>
              <div class="field-group"></div>
            </div>
          </div>
        </div>

        <!-- Section 6: HOT Tax Info -->
        <div class="calc-section">
          <button class="calc-section-toggle" data-target="sec-hot" type="button">
            HOT Tax (Abilene)
            <svg viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <div class="calc-section-body" id="sec-hot">
            <div class="hot-info">
              <p><strong>Hotel Occupancy Tax (HOT) — Abilene, TX</strong><br />
              HOT tax is collected and remitted directly by Airbnb on behalf of the host.
              It does not appear as a cost to the operator and does not impact the P&amp;L model.
              No action required.</p>
            </div>
          </div>
        </div>

        <!-- Notes -->
        <div class="calc-section">
          <button class="calc-section-toggle" data-target="sec-notes" type="button">
            Notes
            <svg viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <div class="calc-section-body" id="sec-notes">
            <div class="field-row full">
              <div class="field-group">
                <label for="inp-notes">Notes</label>
                <textarea id="inp-notes" placeholder="Landlord contact, property condition, negotiation notes…"></textarea>
              </div>
            </div>
          </div>
        </div>

      </div><!-- /calc-panel -->

      <!-- OUTPUT PANEL -->
      <div class="output-panel" id="output-panel">

        <div class="hoa-block" id="hoa-save-block">
          <div class="hoa-block-title">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            HOA Detected — Property Disqualified
          </div>
          <p class="hoa-block-body">Saving and export are disabled. R&amp;L Capital Realty does not lease HOA properties.</p>
        </div>

        <!-- Section 1: Property header -->
        <div class="res-header">
          <div class="res-header-main">
            <div class="res-address" id="res-address">—</div>
            <div class="res-subline" id="res-subline">Select a property to begin</div>
          </div>
          <div class="res-header-side">
            <div class="res-buffer-label">Break-even buffer</div>
            <div class="res-buffer-val" id="res-buffer">—</div>
          </div>
        </div>
        <div id="res-badge" class="res-badge" style="display:none"></div>

        <!-- Section 2: Metric cards -->
        <div class="res-metrics">
          <div class="res-metric" id="rmc-net-monthly">
            <div class="rmc-val" id="res-net-monthly">—</div>
            <div class="rmc-label">Net / month</div>
            <div class="rmc-sub" id="res-margin-sub">— margin</div>
          </div>
          <div class="res-metric" id="rmc-net-annual">
            <div class="rmc-val" id="res-net-annual">—</div>
            <div class="rmc-label">Net / year</div>
            <div class="rmc-sub">base case</div>
          </div>
          <div class="res-metric">
            <div class="rmc-val" id="res-roi12">—</div>
            <div class="rmc-label">12-mo ROI</div>
            <div class="rmc-sub" id="res-roi-sub">—</div>
          </div>
          <div class="res-metric">
            <div class="rmc-val" id="res-payback">—</div>
            <div class="rmc-label">Payback</div>
            <div class="rmc-sub" id="res-mult-sub">—</div>
          </div>
        </div>

        <!-- Section 3: Two-column chart row -->
        <div class="res-chart-row">
          <div class="res-chart-card">
            <div class="rcc-title">Revenue waterfall</div>
            <div style="position:relative;height:220px">
              <canvas id="chart-waterfall"></canvas>
            </div>
          </div>
          <div class="res-chart-card">
            <div class="rcc-title">Break-even vs actual occupancy</div>
            <div class="gauge-wrap">
              <canvas id="chart-gauge" width="220" height="130"></canvas>
            </div>
            <div class="gauge-legend" id="gauge-legend"></div>
            <div class="rcc-title" style="margin-top:14px">Scenario outcomes</div>
            <div style="position:relative;height:80px">
              <canvas id="chart-scenarios"></canvas>
            </div>
          </div>
        </div>

        <!-- Section 4: Monthly cash flow -->
        <div class="res-chart-card">
          <div class="rcc-title">Estimated monthly cash flow</div>
          <div style="position:relative;height:140px">
            <canvas id="chart-monthly"></canvas>
          </div>
          <div class="rcc-footnote" id="monthly-footnote"></div>
          <div class="rcc-market-note" id="market-note"></div>
        </div>

        <!-- Section 5: ROI curve -->
        <div class="res-chart-card">
          <div class="rcc-title">Cumulative ROI — 24-month payback curve</div>
          <div style="position:relative;height:140px">
            <canvas id="chart-roi"></canvas>
          </div>
          <div class="rcc-footnote" id="roi-footnote"></div>
        </div>

        <!-- P&L Statement -->
        <div class="res-chart-card">
          <div class="rcc-title">Monthly P&amp;L Statement — Base Case</div>
          <table class="pl-table">
            <tbody>
              <tr class="pl-section-hd"><td colspan="2">Revenue</td></tr>
              <tr><td>Gross Revenue (ADR × Occ × 30 nights)</td><td id="pl-gross-revenue" class="pl-amount"></td></tr>
              <tr class="pl-section-hd"><td colspan="2">Cost of Revenue</td></tr>
              <tr><td id="pl-airbnb-label">Airbnb Host Fee (3%)</td><td id="pl-airbnb-fee" class="pl-amount pl-cost"></td></tr>
              <tr class="pl-divider"><td colspan="2"></td></tr>
              <tr class="pl-subtotal"><td>Net Platform Revenue</td><td id="pl-net-platform" class="pl-amount"></td></tr>
              <tr class="pl-section-hd"><td colspan="2">Fixed Costs</td></tr>
