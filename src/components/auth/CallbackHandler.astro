---
---

<div class="page-bg"></div>
<div class="grid-lines"></div>

<header class="site-header">
  <a href="/" class="wordmark">
    <span>R<span class="wordmark-accent">&</span>L Capital Realty</span>
    <span class="wordmark-divider"></span>
    <span class="wordmark-sub">LLC</span>
  </a>
</header>

<main>
  <div class="card">

    <!-- VIEW: Loading -->
    <div class="view active" id="view-loading">
      <div class="card-eyebrow">Please wait</div>
      <h1 class="card-title">Verifying<br><em>your link</em></h1>
      <p style="font-size:.9rem;color:#7a6e65">Validating your reset link&hellip;</p>
    </div>

    <!-- VIEW: Set new password -->
    <div class="view" id="view-reset">
      <div class="card-eyebrow">Owner Portal</div>
      <h1 class="card-title">Set new<br><em>password</em></h1>

      <div class="alert alert-error" id="reset-error" role="alert"></div>

      <form id="reset-form" novalidate>
        <div class="form-group">
          <label class="form-label" for="new-password">New Password</label>
          <div class="input-wrap">
            <input id="new-password" name="password" type="password" class="form-input" placeholder="••••••••" autocomplete="new-password" required />
            <button type="button" class="toggle-pw" aria-label="Toggle password visibility" data-target="new-password">
              <svg class="eye-on" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
              <svg class="eye-off" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
            </button>
          </div>
          <span class="password-hint">Minimum 8 characters</span>
        </div>
        <div class="form-group">
          <label class="form-label" for="confirm-password">Confirm Password</label>
          <div class="input-wrap">
            <input id="confirm-password" name="confirm" type="password" class="form-input" placeholder="••••••••" autocomplete="new-password" required />
            <button type="button" class="toggle-pw" aria-label="Toggle password visibility" data-target="confirm-password">
              <svg class="eye-on" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
              <svg class="eye-off" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
            </button>
          </div>
          <span class="password-hint" id="mismatch-hint" style="display:none;color:#c0392b">Passwords do not match</span>
        </div>
        <button type="submit" class="btn-submit" id="reset-btn">
          <div class="btn-spinner"></div>
          <span class="btn-text">Update Password</span>
        </button>
      </form>
    </div>

    <!-- VIEW: Invalid/expired link -->
    <div class="view" id="view-invalid">
      <div class="card-eyebrow">Link Expired</div>
      <h1 class="card-title">This link has<br><em>expired</em></h1>
      <p style="font-size:.88rem;color:#7a6e65;margin-bottom:28px;line-height:1.65">
        Password reset links are valid for one hour. Please request a new one.
      </p>
      <a href="/auth/login" style="display:inline-flex;align-items:center;gap:8px;padding:12px 28px;background:#0f1f2e;color:#faf8f4;font-family:'DM Sans',system-ui,sans-serif;font-size:.78rem;font-weight:500;letter-spacing:.12em;text-transform:uppercase;text-decoration:none;border-radius:2px;transition:background .35s">
        Back to sign in &rarr;
      </a>
    </div>

  </div>
</main>

<footer class="site-footer">
  <a href="/">rlcapitalrealty.com</a> &nbsp;&middot;&nbsp; &copy; 2026 R&amp;L Capital Realty LLC
</footer>

<script>
  import { supabase } from '@lib/supabase';

  const views = {
    loading: document.getElementById('view-loading')!,
    reset:   document.getElementById('view-reset')!,
    invalid: document.getElementById('view-invalid')!,
  };

  function showView(name: 'loading' | 'reset' | 'invalid') {
    Object.values(views).forEach(v => v.classList.remove('active'));
    views[name].classList.add('active');
  }

  const resetError = document.getElementById('reset-error')!;
  const resetBtn   = document.getElementById('reset-btn') as HTMLButtonElement;

  function setLoading(on: boolean) {
    resetBtn.disabled = on;
    resetBtn.classList.toggle('loading', on);
  }

  const newPwInput     = document.getElementById('new-password') as HTMLInputElement;
  const confirmPwInput = document.getElementById('confirm-password') as HTMLInputElement;
  const mismatchHint   = document.getElementById('mismatch-hint')!;

  function checkMatch() {
    if (confirmPwInput.value.length === 0) { mismatchHint.style.display = 'none'; return; }
    mismatchHint.style.display = newPwInput.value !== confirmPwInput.value ? '' : 'none';
  }

  newPwInput.addEventListener('input', checkMatch);
  confirmPwInput.addEventListener('input', checkMatch);

  document.querySelectorAll<HTMLButtonElement>('.toggle-pw').forEach(btn => {
    btn.addEventListener('click', () => {
      const input = document.getElementById(btn.dataset.target!) as HTMLInputElement;
      input.type = input.type === 'password' ? 'text' : 'password';
      btn.classList.toggle('shown');
    });
  });

  const timeout = setTimeout(() => showView('invalid'), 4000);

  supabase.auth.onAuthStateChange(async (event) => {
    clearTimeout(timeout);
    if (event === 'PASSWORD_RECOVERY') {
      showView('reset');
    } else if (event === 'SIGNED_IN') {
      window.location.replace('/admin');
    }
  });

  document.getElementById('reset-form')!.addEventListener('submit', async e => {
    e.preventDefault();
    resetError.classList.remove('show');
    const password = newPwInput.value;
    const confirm  = confirmPwInput.value;
    if (password.length < 8) {
      resetError.textContent = 'Password must be at least 8 characters.';
      resetError.classList.add('show');
      return;
    }
    if (password !== confirm) {
      resetError.textContent = 'Passwords do not match.';
      resetError.classList.add('show');
      return;
    }
    setLoading(true);
    const { error } = await supabase.auth.updateUser({ password });
    setLoading(false);
    if (error) {
      resetError.textContent = 'Could not update your password. Please request a new reset link.';
      resetError.classList.add('show');
    } else {
      window.location.replace('/admin');
    }
  });
</script>

<style>
  body { font-family: 'DM Sans', system-ui, sans-serif; background: #0f1f2e; color: #3d3530; font-size: 16px; line-height: 1.6; display: flex; flex-direction: column; min-height: 100vh; overflow-x: hidden; }
  .page-bg { position: fixed; inset: 0; pointer-events: none; overflow: hidden; z-index: 0; }
  .page-bg::before { content: ''; position: absolute; width: 700px; height: 700px; border-radius: 50%; background: radial-gradient(circle, rgba(201,169,110,.06) 0%, transparent 70%); top: -200px; right: -200px; }
  .page-bg::after { content: ''; position: absolute; width: 500px; height: 500px; border-radius: 50%; background: radial-gradient(circle, rgba(201,169,110,.04) 0%, transparent 70%); bottom: -150px; left: -100px; }
  .grid-lines { position: fixed; inset: 0; z-index: 0; pointer-events: none; background-image: linear-gradient(rgba(201,169,110,.03) 1px, transparent 1px), linear-gradient(90deg, rgba(201,169,110,.03) 1px, transparent 1px); background-size: 60px 60px; }
  .site-header { position: relative; z-index: 10; padding: 28px 5vw; display: flex; align-items: center; }
  .wordmark { font-family: 'Cormorant Garamond', Georgia, serif; font-weight: 400; font-size: 1.1rem; letter-spacing: .04em; color: #faf8f4; text-decoration: none; display: flex; align-items: center; gap: 10px; }
  .wordmark-accent { color: #c9a96e; }
  .wordmark-divider { width: 1px; height: 16px; background: rgba(201,169,110,.35); }
  .wordmark-sub { font-family: 'DM Sans', system-ui, sans-serif; font-size: .6rem; font-weight: 300; letter-spacing: .14em; color: rgba(250,248,244,.45); text-transform: uppercase; }
  main { flex: 1; display: flex; align-items: center; justify-content: center; padding: 24px 5vw 60px; position: relative; z-index: 1; }
  .card { background: #faf8f4; width: 100%; max-width: 420px; padding: 48px 44px; position: relative; overflow: hidden; box-shadow: 0 32px 80px rgba(0,0,0,.35), 0 0 0 1px rgba(201,169,110,.12); }
  .card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, #a8885a, #c9a96e, #a8885a); }
  .card-eyebrow { font-family: 'DM Sans', system-ui, sans-serif; font-size: .65rem; font-weight: 500; letter-spacing: .2em; text-transform: uppercase; color: #a8885a; display: flex; align-items: center; gap: 10px; margin-bottom: 14px; }
  .card-eyebrow::before { content: ''; display: block; width: 22px; height: 1px; background: #a8885a; }
  .card-title { font-family: 'Cormorant Garamond', Georgia, serif; font-weight: 400; font-size: 2rem; color: #0f1f2e; line-height: 1.15; margin-bottom: 32px; letter-spacing: -.01em; }
  .card-title em { font-style: italic; color: #a8885a; }
  .form-group { display: flex; flex-direction: column; gap: 6px; margin-bottom: 20px; }
  .form-label { font-size: .72rem; font-weight: 500; letter-spacing: .1em; text-transform: uppercase; color: #7a6e65; }
  .form-input { width: 100%; padding: 12px 14px; border: 1px solid rgba(15,31,46,.15); border-radius: 2px; font-family: 'DM Sans', system-ui, sans-serif; font-size: .95rem; color: #0f1f2e; background: white; outline: none; transition: border-color .35s, box-shadow .35s; }
  .form-input:focus { outline: none; border-color: #c9a96e; box-shadow: 0 0 0 3px rgba(201,169,110,.22); }
  .form-input:focus-visible { border-color: #c9a96e; box-shadow: 0 0 0 3px rgba(201,169,110,.22); }
  .form-input::placeholder { color: #8a7e78; }
  .input-wrap { position: relative; }
  .input-wrap .form-input { padding-right: 42px; }
  .toggle-pw { position: absolute; right: 12px; top: 50%; transform: translateY(-50%); background: none; border: none; padding: 4px; cursor: pointer; color: #7a6e65; line-height: 0; transition: color .35s; }
  .toggle-pw:hover { color: #0f1f2e; }
  .toggle-pw .eye-off { display: none; }
  .toggle-pw.shown .eye-on { display: none; }
  .toggle-pw.shown .eye-off { display: block; }
  .btn-submit { width: 100%; padding: 13px 24px; background: #0f1f2e; color: #faf8f4; font-family: 'DM Sans', system-ui, sans-serif; font-size: .78rem; font-weight: 500; letter-spacing: .12em; text-transform: uppercase; border: none; border-radius: 2px; cursor: pointer; transition: background .35s, transform .35s, box-shadow .35s; display: flex; align-items: center; justify-content: center; gap: 10px; margin-top: 8px; }
  .btn-submit:hover:not(:disabled) { background: #243a52; transform: translateY(-1px); box-shadow: 0 8px 24px rgba(15,31,46,.3); }
  .btn-submit:disabled { opacity: .6; cursor: not-allowed; }
  .btn-spinner { width: 14px; height: 14px; border: 2px solid rgba(250,248,244,.3); border-top-color: #faf8f4; border-radius: 50%; animation: spin .7s linear infinite; display: none; }
  .btn-submit.loading .btn-spinner { display: block; }
  .btn-submit.loading .btn-text { opacity: .7; }
  @keyframes spin { to { transform: rotate(360deg); } }
  .alert { padding: 12px 14px; border-radius: 2px; font-size: .85rem; line-height: 1.5; margin-bottom: 20px; display: none; }
  .alert.show { display: block; }
  .alert-error { background: rgba(192,57,43,.07); border: 1px solid rgba(192,57,43,.35); color: #c0392b; }
  .password-hint { font-size: .75rem; color: #7a6e65; margin-top: 4px; }
  .view { display: none; }
  .view.active { display: block; }
  .site-footer { position: relative; z-index: 1; text-align: center; padding: 20px 5vw 32px; font-size: .72rem; color: rgba(250,248,244,.25); letter-spacing: .06em; }
  .site-footer a { color: rgba(250,248,244,.35); text-decoration: none; transition: color .35s; }
  .site-footer a:hover { color: #c9a96e; }
  @media (max-width: 480px) { .card { padding: 36px 28px; } }
</style>
