              <tr><td>Bulk Pickup</td><td id="pl-bulk-pickup" class="pl-amount pl-cost"></td></tr>
              <tr><td>Maintenance Reserve</td><td id="pl-maintenance" class="pl-amount pl-cost"></td></tr>
