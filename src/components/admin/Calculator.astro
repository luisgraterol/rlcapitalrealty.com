            <div class="metric-row"><span class="metric-label">Cleaning Collected</span><span class="metric-value" id="out-cleaning-collected">—</span></div>
            <div class="metric-row"><span class="metric-label">Cleaning Paid</span><span class="metric-value" id="out-cleaning-paid">—</span></div>
