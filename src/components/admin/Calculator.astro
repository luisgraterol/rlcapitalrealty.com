    position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%);
    width: 480px; max-width: calc(100vw - 32px); max-height: 90vh; overflow-y: auto;
    background: #ffffff; border: 1px solid rgba(15,31,46,.12);
    box-shadow: 0 8px 40px rgba(15,31,46,.18); z-index: 201; border-radius: 3px;
  }
  .modal-header { display: flex; align-items: center; justify-content: space-between; padding: 22px 24px 16px; border-bottom: 1px solid rgba(15,31,46,.08); }
  .modal-title { font-family: 'Cormorant Garamond', Georgia, serif; font-size: 1.1rem; font-weight: 500; color: #0f1f2e; }
  .modal-close { background: none; border: none; cursor: pointer; font-size: 1.4rem; color: rgba(15,31,46,.4); line-height: 1; padding: 4px 8px; transition: color .2s; }
  .modal-close:hover { color: #0f1f2e; }
  .modal-body { padding: 20px 24px 24px; display: flex; flex-direction: column; gap: 12px; }
  .modal-error { background: rgba(201,74,74,.1); border: 1px solid rgba(201,74,74,.3); color: #c94a4a; padding: 10px 14px; border-radius: 2px; font-size: .82rem; }
  .modal-actions { display: flex; gap: 10px; justify-content: flex-end; padding-top: 8px; border-top: 1px solid rgba(15,31,46,.08); margin-top: 4px; }

  /* Quick-create landlord */
  .quick-landlord-toggle { margin-top: -4px; }
  .link-btn { background: none; border: none; cursor: pointer; display: inline-flex; align-items: center; gap: 5px; font-family: 'DM Sans', system-ui, sans-serif; font-size: .72rem; color: #a8885a; letter-spacing: .04em; padding: 0; transition: color .2s; }
  .link-btn:hover { color: #c9a96e; }
  .quick-landlord-form { background: rgba(201,169,110,.05); border: 1px solid rgba(201,169,110,.15); border-radius: 2px; padding: 16px; display: flex; flex-direction: column; gap: 10px; margin-top: 4px; }
  .ql-title { font-size: .65rem; letter-spacing: .16em; text-transform: uppercase; color: #a8885a; font-weight: 500; margin-bottom: 2px; }

  footer { border-top: 1px solid rgba(201,169,110,.1); padding: 24px 5vw; display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap; position: relative; z-index: 1; }
  .footer-brand { font-family: 'Cormorant Garamond', Georgia, serif; font-size: .95rem; color: rgba(15,31,46,.65); letter-spacing: .04em; }
  .footer-brand span { color: #a8885a; }
  .footer-meta { font-size: .72rem; color: #7a6e65; letter-spacing: .06em; }

  @media (max-width: 1024px) { .calc-layout { grid-template-columns: 1fr; } .output-panel { position: static; } }
  @media (max-width: 600px) { .portal-content { padding: 32px 5vw 60px; } .field-row { grid-template-columns: 1fr; } .calc-panel, .output-panel { padding: 22px 16px; } }
</style>
