  .field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 10px; }
  .field-row.full { grid-template-columns: 1fr; }
  .field-group { display: flex; flex-direction: column; gap: 4px; }
  label { font-size: .68rem; letter-spacing: .1em; text-transform: uppercase; color: #7a6e65; font-weight: 400; }
  .req { color: #c94a4a; font-style: normal; }
  input[type="text"], input[type="number"], input[type="email"], select, textarea { background: #ffffff; border: 1px solid rgba(15,31,46,.15); border-radius: 2px; padding: 9px 12px; font-family: 'DM Sans', system-ui, sans-serif; font-size: .88rem; color: #0f1f2e; width: 100%; transition: border-color .35s, background .35s; -webkit-appearance: none; appearance: none; }
  input:focus, select:focus, textarea:focus { outline: none; border-color: #c9a96e; background: rgba(201,169,110,.04); }
  input[readonly], input[disabled] { opacity: .5; cursor: not-allowed; background: rgba(15,31,46,.03); }
  input.prop-auto-field { opacity: 1; cursor: default; color: rgba(15,31,46,.6); font-style: italic; }
  input::placeholder, textarea::placeholder { color: #8a7e78; }
  select option { background: #ffffff; color: #0f1f2e; }
  textarea { resize: vertical; min-height: 72px; line-height: 1.5; }
  .field-note { font-size: .72rem; color: #7a6e65; line-height: 1.4; font-style: italic; margin-top: 2px; }
  .field-badge { display: inline-flex; align-items: center; gap: 6px; padding: 3px 8px; border: 1px solid rgba(201,169,110,.2); border-radius: 2px; font-size: .65rem; letter-spacing: .1em; text-transform: uppercase; color: rgba(201,169,110,.6); font-style: normal; }

  .hoa-block { display: none; background: rgba(201,74,74,.12); border: 2px solid #c94a4a; border-radius: 2px; padding: 16px 18px; margin-top: 12px; }
  .hoa-block.visible { display: block; }
  .hoa-block-title { font-family: 'DM Sans', system-ui, sans-serif; font-size: .8rem; font-weight: 500; letter-spacing: .08em; text-transform: uppercase; color: #c94a4a; margin-bottom: 6px; display: flex; align-items: center; gap: 8px; }
  .hoa-block-body { font-size: .88rem; color: rgba(201,74,74,.9); line-height: 1.6; }
  .hot-info { background: rgba(201,169,110,.05); border: 1px solid rgba(201,169,110,.15); border-radius: 2px; padding: 14px 16px; margin-top: 8px; }
  .hot-info p { font-size: .88rem; color: #7a6e65; line-height: 1.65; }
  .hot-info strong { color: rgba(15,31,46,.7); font-weight: 400; }

  .output-panel { background: #ffffff; border: 1px solid rgba(15,31,46,.1); box-shadow: 0 1px 4px rgba(15,31,46,.06); padding: 32px 28px; display: flex; flex-direction: column; gap: 24px; position: sticky; top: 20px; }
  .out-section-title { font-family: 'DM Sans', system-ui, sans-serif; font-size: .65rem; font-weight: 500; letter-spacing: .18em; text-transform: uppercase; color: #a8885a; margin-bottom: 14px; padding-bottom: 8px; border-bottom: 1px solid rgba(201,169,110,.08); }
  .metric-row { display: flex; justify-content: space-between; align-items: baseline; padding: 5px 0; border-bottom: 1px solid rgba(15,31,46,.06); font-size: .83rem; gap: 8px; }
  .metric-row:last-child { border-bottom: none; }
  .metric-label { color: #7a6e65; font-weight: 300; flex-shrink: 0; }
  .metric-value { font-weight: 400; letter-spacing: .02em; text-align: right; color: #0f1f2e; }
  .metric-value.green { color: #4caf81; }
  .metric-value.amber { color: #d4a32a; }
  .metric-value.red   { color: #c94a4a; }
  .metric-row.highlight { background: rgba(15,31,46,.04); margin: 0 -8px; padding: 7px 8px; border-bottom: 1px solid rgba(15,31,46,.06); }
  .metric-row.highlight .metric-label { color: rgba(15,31,46,.65); font-weight: 400; }
  .metric-row.highlight .metric-value { font-size: .95rem; }
  .metric-row--gross { padding-bottom: 10px; }
  .cost-stack-label { font-size: .62rem; letter-spacing: .14em; text-transform: uppercase; color: #a8885a; font-weight: 500; padding: 8px 0 4px; border-top: 1px solid rgba(201,169,110,.12); margin-top: 4px; }
  .metric-row.cost-item { padding: 4px 0 4px 10px; font-size: .8rem; border-bottom: 1px solid rgba(15,31,46,.04); }
  .metric-row.cost-item .metric-label { color: rgba(15,31,46,.55); font-weight: 300; }
  .metric-row--total { border-top: 1px solid rgba(15,31,46,.12); margin-top: 2px; padding-top: 7px; font-weight: 500; }
  .metric-row--total .metric-label { color: rgba(15,31,46,.75); font-weight: 500; }
  .passthrough-note { font-size: .75rem; color: #7a6e65; font-style: italic; margin-bottom: 10px; line-height: 1.5; }

  .scenario-table { width: 100%; border-collapse: collapse; font-size: .8rem; margin-top: 8px; }
  .scenario-table th { font-size: .68rem; letter-spacing: .12em; text-transform: uppercase; color: #7a6e65; font-weight: 400; padding: 12px 16px; text-align: right; border-bottom: 1px solid rgba(15,31,46,.08); }
  .scenario-table th:first-child { text-align: left; }
  .scenario-table td { padding: 11px 16px; font-size: .92rem; color: #0f1f2e; border-bottom: 1px solid rgba(15,31,46,.08); text-align: right; }
  .scenario-table td:first-child { text-align: left; color: rgba(15,31,46,.5); font-size: .75rem; letter-spacing: .06em; text-transform: uppercase; }
  .scenario-table tr.worst-negative td { background: rgba(201,74,74,.08); color: #c94a4a; }
